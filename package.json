{
  "name": "auto-reviewer",
  "version": "0.1.0",
  "description": "Polling PR auto-reviewer that uses the Claude Max plan via `claude -p`.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "review-once": "bun src/cli/review-once.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
