# GitHub personal access token for the reviewer account.
# Needs: repo (read), pull_request (read+write for reviews).
# Reviews posted by this user are what count toward branch-protection approvals,
# so this MUST NOT be your own account (the "not me" filter is keyed off
# github.bot_username in the UI; add your personal login to skip_authors).
GITHUB_TOKEN=

# Optional. sqlite path. Defaults to ./data/state.sqlite.
# AUTO_REVIEWER_DB=/app/data/state.sqlite

# Optional. One-time YAML bootstrap path. If the DB is empty and this file
# exists at first boot, its values are imported into the DB and it is ignored
# afterwards. The UI becomes the source of truth.
# AUTO_REVIEWER_CONFIG=/app/config.yaml

# Optional. Web UI bind host/port. In docker-compose the container listens on
# 0.0.0.0:8787 and the host maps 127.0.0.1:8787 only.
# AUTO_REVIEWER_WEB_HOST=127.0.0.1
# AUTO_REVIEWER_WEB_PORT=8787

# Optional. When set, gates the web UI behind HTTP Basic auth. Username is
# fixed to "admin"; this variable is the password. Required if you bind to
# anything other than 127.0.0.1 (e.g. exposing via reverse proxy / VPN).
# /healthz stays open so healthchecks and proxies work without credentials.
# AUTO_REVIEWER_PASSWORD=

# Optional. Prune events table at startup, removing entries older than N days.
# Default 30. Set to 0 or a negative number to disable pruning.
# AUTO_REVIEWER_EVENT_RETENTION_DAYS=30

# Optional. Label recorded in the audit log when the current operator makes a
# config change. Defaults to "operator". When GitHub OAuth lands the session
# login will replace this automatically, so set it now to whatever you'd like
# to see in the Events page payload (e.g. your handle or email).
# AUTO_REVIEWER_OPERATOR=william

# Optional. GitHub OAuth App client secret. When set alongside the
# github.oauth_client_id config scalar (editable in the UI), the app
# switches from single-shared-password basic auth to session-based GitHub
# OAuth. The first person to sign in is auto-promoted to admin; subsequent
# logins arrive as viewers until an admin promotes them. Leave empty to
# keep the existing basic-auth model.
# GITHUB_OAUTH_CLIENT_SECRET=

# Optional. Shared secret used to verify GitHub webhook signatures. When set,
# POST /webhook/github accepts GitHub's webhook deliveries and enqueues the
# PR for immediate review (instead of waiting for the next poll). Must match
# the "Secret" configured on the GitHub App / repo webhook. If unset, the
# endpoint responds 503 and polling stays the only ingest path.
# GITHUB_WEBHOOK_SECRET=

# Optional. TTL for the webhook deduplication table (days). The endpoint
# drops duplicate X-GitHub-Delivery IDs; old rows are pruned on boot so
# the table doesn't grow unbounded. Default 14 days.
# AUTO_REVIEWER_WEBHOOK_RETENTION_DAYS=14

# Optional. Claude circuit breaker — trips after N consecutive claude.failed
# events across any PRs, stays open for M seconds, then tries once (half-open)
# before fully closing on success or re-opening on failure. Protects the Max
# quota when the session is expired, rate-limited, or the network's flaky.
# Defaults: threshold=5 consecutive failures, cooldown=900s (15min).
# AUTO_REVIEWER_BREAKER_THRESHOLD=5
# AUTO_REVIEWER_BREAKER_COOLDOWN_SECONDS=900
