# arbiter — environment configuration

# HTTP server
PORT=8787
PUBLIC_URL=http://localhost:8787

# Postgres (in docker-compose this is the internal hostname)
DATABASE_URL=postgres://arbiter:arbiter@db:5432/arbiter

# Session signing secret (random 32+ bytes, hex)
SESSION_SECRET=change_me_to_random_hex

# GitHub OAuth App credentials
# Create at https://github.com/settings/developers (Authorization callback URL = $PUBLIC_URL/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: webhook receiver. Configure a GitHub repo/org webhook pointing
# at $PUBLIC_URL/api/webhooks/github (content type application/json, event:
# Pull requests) with this exact secret. Enables near-instant reviews; the
# poller stays on as a safety net. Leave blank to disable the endpoint.
GITHUB_WEBHOOK_SECRET=

# Optional: GitHub App credentials. When BOTH are set, arbiter can mint
# short-lived, finely-scoped per-installation tokens instead of storing a
# broad OAuth user token at rest. Currently inert (slice 1: credential
# core only — no call site uses it yet); later slices flip the worker over
# once you've registered the App and installed it. Create the App at
# https://github.com/settings/apps, generate a private key, and either
# paste the PEM with literal \n, or base64-encode the whole PEM file.
# Both blank = App auth disabled; the OAuth path is unaffected.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Claude invocation default — "subscription" or "api"
# subscription: shells out to `claude -p` using the host ~/.claude/ credentials
# api: uses ANTHROPIC_API_KEY via @anthropic-ai/sdk (added later)
CLAUDE_DEFAULT_MODE=subscription

# Path to the claude binary on the host (subscription mode)
CLAUDE_BIN=claude

# Host directory bind-mounted to /root/.claude for subscription mode.
# Leave unset on Linux/macOS (defaults to $HOME/.claude). REQUIRED on
# Windows, where $HOME is unset under PowerShell — set it to your creds
# dir with forward slashes, e.g. C:/Users/<you>/.claude
# `bun run setup` fills this in for you. See README → Subscription mode in Docker.
CLAUDE_HOST_DIR=

# Anthropic API key (only used when scope opts into api mode)
ANTHROPIC_API_KEY=

# Polling cadence (seconds) — how often the poller checks GitHub for new PRs
POLL_INTERVAL_SECONDS=60

# Worker cadence (seconds) — how often the worker drains the review queue
WORKER_INTERVAL_SECONDS=5

# Reviews processed concurrently in this process (default 1 = original
# single-at-a-time behavior). The queue claim is FOR UPDATE SKIP LOCKED so
# >1 is safe; raise it to drain a backlog faster. Each slot spends a real
# Claude call, so size against quota/cost. Multi-container deployments
# should run API mode (one shared subscription login can't fan out).
WORKER_CONCURRENCY=1

# Terminal reviews (done/failed/skipped) older than this many days are pruned
# hourly. Set to 0 to disable pruning and keep history forever.
REVIEW_RETENTION_DAYS=30

# Expose the /api/debug/* routes (dry-run a review, manually enqueue). The
# run-review route spends a real Claude call, so this is off by default.
# Set to 1 only in a trusted dev environment.
ENABLE_DEBUG_ENDPOINTS=0

# Bearer token for the Prometheus GET /metrics endpoint. Blank disables it
# entirely (404). When set, the scraper must send
# `Authorization: Bearer <token>`.
METRICS_TOKEN=
