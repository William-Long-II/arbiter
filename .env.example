# Server
PORT=3000
HOSTNAME=127.0.0.1

# GitHub machine-user credentials. The PAT belongs to the reviewer user account;
# its reviews count toward branch protection required-approver rules.
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=
# Optional override — skips the GET /user call at boot. Useful for local dev
# with a placeholder PAT. In production, leave unset so the login is
# authoritatively resolved from the PAT that will actually post reviews.
# GITHUB_MACHINE_USER_LOGIN=review-me-bot

# Anthropic (LLM review)
ANTHROPIC_API_KEY=

# Jira (optional — if unset, bot falls back to PR description for intent)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
