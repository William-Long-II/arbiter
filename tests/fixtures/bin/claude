#!/usr/bin/env sh
# Stub `claude` binary for integration tests.
#
# When invoked with `--version`, prints a version string and exits 0.
# When invoked with `-p`, echoes a canned JSON review result in the
# `--output-format json` envelope format.

case "$1" in
  --version)
    echo "claude 1.0.0 (stub)"
    exit 0
    ;;
  -p)
    # Echo a minimal valid CLI JSON envelope.
    printf '%s\n' '{"type":"result","result":"{\"verdict\":\"approve\",\"summary\":\"Integration test stub review: looks good.\",\"lineComments\":[]}","usage":{"input_tokens":42,"output_tokens":18,"cache_read_input_tokens":0,"cache_creation_input_tokens":0}}'
    exit 0
    ;;
  *)
    echo "stub claude: unknown args: $*" >&2
    exit 1
    ;;
esac
